# 외부 API 키 템플릿. 실제 키를 채워서 .env 로 저장하세요.
# .env 는 .gitignore 에 포함되어 있어 git 에 올라가지 않습니다.

# CV-A: V-World 항공사진 (Mobile-SAM 입력)
# 발급: https://www.vworld.kr → 오픈API → 인증키 발급 (한국, 무료, 즉시)
VWORLD_API_KEY=

# CV-B: Mapillary 거리뷰 (SegFormer 입력)
# 발급: https://www.mapillary.com/dashboard/developers → Register Application
MAPILLARY_TOKEN=

# (선택) GPT-4o-mini 자연어 설치 근거 생성
# 없으면 룰베이스 템플릿 fallback
OPENAI_API_KEY=
